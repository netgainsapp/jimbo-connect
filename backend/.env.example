MONGO_URL=mongodb://localhost:27017
DB_NAME=jimbo_connect
# REQUIRED. Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
# Never deploy with a placeholder: a known signing key lets anyone forge tokens.
JWT_SECRET=
# REQUIRED to bootstrap the single platform admin. If ADMIN_PASSWORD is unset,
# admin bootstrap is skipped (no guessable default is used).
ADMIN_EMAIL=
ADMIN_PASSWORD=
FRONTEND_URL=http://localhost:3000

# Resend (transactional email). Leave blank to fall back to in-app reset URL.
RESEND_API_KEY=
EMAIL_FROM=Jimbo Connect <onboarding@resend.dev>

# CAN-SPAM / deliverability.
# Signing secret for Resend webhooks (resend.com -> Webhooks, starts with whsec_).
# Leave blank to disable the /api/webhooks/resend endpoint entirely.
RESEND_WEBHOOK_SECRET=
# Public base URL of this API, used to build absolute unsubscribe links.
API_PUBLIC_URL=https://jimbo-connect-api-rdkp.onrender.com
# Optional dedicated secret for signing unsubscribe links (falls back to JWT_SECRET).
UNSUBSCRIBE_SECRET=
